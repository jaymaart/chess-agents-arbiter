# =============================================================================
# Docker Sandbox Match Processor — Configuration
# Copy to .env and fill in your values
# =============================================================================

# Broker API
BROKER_URL=https://chess-agents-api-production.up.railway.app/api/broker
BROKER_ID=my-runner-1

# Auth — use ONE of these:
# Option A: RSA key file (path relative to this directory or absolute)
# BROKER_KEY_PATH=broker-key.pem
# Option B: Shared secret
# BROKER_SECRET=your-secret-here

# Execution
MAX_CONCURRENT_MATCHES=10
NIGHT_MAX_CONCURRENT=20
NIGHT_START_HOUR=3
NIGHT_END_HOUR=8
AGENT_MOVE_TIMEOUT_MS=8000
AGENT_MEMORY_LIMIT=256m
POLL_INTERVAL_MS=5000
BATCH_SIZE=10

# Docker sandbox image (build from docker/Dockerfile.agent)
SANDBOX_IMAGE=agentchess-sandbox:latest
